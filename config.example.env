# Copy to your local shell profile, launchd plist, or private deployment config.
# Do not commit real values.

# Runtime listen port for local iOS direct WebSocket connections.
CCCODE_BRIDGE_PORT=8777

# Optional OpenCode auth used only when your local OpenCode server requires it.
OPENCODE_SERVER_USERNAME=
OPENCODE_SERVER_PASSWORD=

# Optional Codex app-server backend.
CODEX_APP_SERVER_URL=ws://localhost:4141

# Optional relay endpoint. Use your own relay-server deployment.
CCCODE_RELAY_ENDPOINT=wss://relay.example.com
